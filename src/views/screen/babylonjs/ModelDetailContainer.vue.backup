<template>
  <div class="model-detail-container">
    <!-- BabylonJS Canvas -->
    <canvas id="renderCanvas" class="babylon-canvas"></canvas>

    <!-- 顶部工具栏 -->
    <div class="babylon-toolbar">
      <div class="toolbar-content">
        <router-link to="/map" class="back-link">
          <el-icon><ArrowLeft /></el-icon>
          <span>返回地图</span>
        </router-link>
        <span class="title">3D模型详情 - {{ currentWindmillName }}</span>
        <div class="toolbar-actions">
          <el-button size="small" @click="resetCamera">
            <el-icon><Refresh /></el-icon>
            重置视角
          </el-button>
          <el-button size="small" @click="toggleMeasurement">
            <el-icon><Measurement /></el-icon>
            {{ isMeasuring ? '停止测量' : '开始测量' }}
          </el-button>
          <el-button size="small">
            <el-icon><Download /></el-icon>
            导出
          </el-button>
        </div>
      </div>
    </div>

    <!-- 左侧树形面板（风机选择和测量工具） -->
    <Transition name="slide-fade">
      <div v-show="leftPanelOpen" class="left-panel">
        <!-- 标签页 -->
        <el-tabs type="card">
          <!-- 风机选择标签页 -->
          <el-tab-pane label="风机列表" name="windmills">
            <div class="panel-content">
              <el-tree
                ref="treeRef"
                :data="treeData"
                node-key="id"
                :props="{ children: 'children', label: 'label' }"
                @node-click="handleTreeNodeClick"
                :default-expanded-keys="[currentFarmId]"
                highlight-current
              >
                <template #default="{ node, data }">
                  <div
                    class="tree-node"
                    :class="{ active: data.id === currentWindmillId }"
                  >
                    <span v-if="data.type === 'farm'" class="farm-node">
                      <el-icon><DataAnalysis /></el-icon>
                      {{ node.label }}
                    </span>
                    <span v-else class="windmill-node">
                      <el-icon :class="getStatusIconClass(data.data?.status)">
                        <CircleCloseFilled />
                      </el-icon>
                      {{ node.label }}
                    </span>
                  </div>
                </template>
              </el-tree>
            </div>
          </el-tab-pane>

          <!-- 测量工具标签页 -->
          <el-tab-pane label="测量工具" name="measurement">
            <div class="panel-content">
              <!-- 方量计算部分 -->
              <div class="cut-fill-section">
                <el-divider>挖填方计算</el-divider>
                
                <!-- 基准高度输入 -->
                <div class="input-group">
                  <label>基准高度 (m)</label>
                  <el-input-number
                    v-model="targetHeight"
                    :min="-1000"
                    :max="1000"
                    :step="0.1"
                    :precision="2"
                    placeholder="输入基准面高度"
                    style="width: 100%"
                  />
                </div>

                <!-- 采样分辨率 -->
                <div class="input-group">
                  <label>采样分辨率 (m)</label>
                  <el-input-number
                    v-model="sampleResolution"
                    :min="0.1"
                    :max="5"
                    :step="0.1"
                    :precision="2"
                    placeholder="采样分辨率（越小精度越高但速度越慢）"
                    style="width: 100%"
                  />
                </div>

                <!-- 计算按钮 -->
                <el-button
                  type="primary"
                  :loading="isModelLoading"
                  @click="calculateCutFill"
                  style="width: 100%"
                >
                  计算方量
                </el-button>

                <!-- 计算结果显示 -->
                <div v-if="measureResult" class="result-display">
                  <el-card shadow="hover" style="margin-top: 10px">
                    <template #header>
                      <div style="display: flex; justify-content: space-between">
                        <span>计算结果</span>
                        <el-button link @click="saveMeasurement">保存</el-button>
                      </div>
                    </template>
                    <el-row :gutter="10">
                      <el-col :span="24">
                        <el-statistic 
                          title="挖方体积" 
                          :value="`@{measureResult.cutVolume} m³`"
                          style="text-align: center"
                        />
                      </el-col>
                      <el-col :span="24">
                        <el-statistic 
                          title="填方体积" 
                          :value="`@{measureResult.fillVolume} m³`"
                          style="text-align: center"
                        />
                      </el-col>
                      <el-col :span="24">
                        <el-statistic 
                          title="水平投影面积" 
                          :value="`@{measureResult.horizontalArea} m²`"
                          style="text-align: center"
                        />
                      </el-col>
                    </el-row>
                  </el-card>
                </div>
              </div>

              <el-divider>传统测量</el-divider>

              <!-- 测量模式选择 -->
              <div class="measure-mode">
                <label>测量模式</label>
                <el-radio-group v-model="measureMode" @change="handleMeasureMode">
                  <el-radio label="distance">距离</el-radio>
                  <el-radio label="area">面积</el-radio>
                  <el-radio label="volume">体积</el-radio>
                </el-radio-group>
              </div>

              <!-- 测量点列表 -->
              <div class="measure-points">
                <label>测量点 ({{ measurePoints.length }})</label>
                <div class="points-list">
                  <div
                    v-for="(point, index) in measurePoints"
                    :key="index"
                    class="point-item"
                  >
                    <span class="point-num">{{ index + 1 }}</span>
                    <span class="point-coords">
                      X: {{ point.x.toFixed(2) }}, Y: {{ point.y.toFixed(2) }}, Z:
                      {{ point.z.toFixed(2) }}
                    </span>
                    <el-icon class="delete-btn" @click="deletePoint(index)">
                      <Delete />
                    </el-icon>
                  </div>
                </div>
              </div>

              <!-- 已保存的测量结果 -->
              <div class="saved-results">
                <label>已保存的测量 ({{ savedResults.length }})</label>
                <div class="results-list">
                  <div
                    v-for="(result, index) in savedResults"
                    :key="index"
                    class="result-item"
                  >
                    <span class="result-type">{{ result.type }}</span>
                    <span class="result-value">{{ result.value.toFixed(2) }} {{ result.unit }}</span>
                    <el-icon class="delete-btn" @click="deleteSavedResult(index)">
                      <Delete />
                    </el-icon>
                  </div>
                </div>
              </div>
            </div>
          </el-tab-pane>
        </el-tabs>
      </div>
    </Transition>

    <!-- 右侧信息面板 -->
    <Transition name="slide-fade-right">
      <div v-show="infoPanelOpen" class="info-panel">
        <div class="panel-content">
          <el-card v-if="currentWindmillData && underwaterModel" shadow="hover">
            <template #header>
              <div class="card-header">
                <span>{{ currentWindmillName }}</span>
              </div>
            </template>

            <!-- 风机基本信息 -->
            <el-descriptions title="风机信息" :column="1" border>
              <el-descriptions-item label="设备编号">
                {{ currentWindmillData.code }}
              </el-descriptions-item>
              <el-descriptions-item label="装机容量">
                {{ currentWindmillData.power }} kW
              </el-descriptions-item>
              <el-descriptions-item label="运行状态">
                <el-tag :type="getStatusTagType(currentWindmillData.status)">
                  {{ getStatusLabel(currentWindmillData.status) }}
                </el-tag>
              </el-descriptions-item>
              <el-descriptions-item label="位置坐标">
                {{ currentWindmillData.position.lng }}, {{ currentWindmillData.position.lat }}
              </el-descriptions-item>
            </el-descriptions>

            <el-divider />

            <!-- 水下模型信息 -->
            <el-descriptions title="模型信息" :column="1" border>
              <el-descriptions-item label="模型类型">
                {{ underwaterModel.modelType }}
              </el-descriptions-item>
              <el-descriptions-item label="描述">
                {{ underwaterModel.description }}
              </el-descriptions-item>
            </el-descriptions>

            <el-divider />

            <!-- 模型统计 -->
            <h4>模型统计</h4>
            <el-row :gutter="20">
              <el-col :span="12">
                <el-statistic title="顶点数" :value="underwaterModel.vertices" />
              </el-col>
              <el-col :span="12">
                <el-statistic title="面数" :value="underwaterModel.faces" />
              </el-col>
            </el-row>
            <el-row :gutter="20">
              <el-col :span="12">
                <el-statistic title="材质数" :value="underwaterModel.materials" />
              </el-col>
              <el-col :span="12">
                <el-statistic title="文件大小" :value="underwaterModel.fileSize" suffix=" MB" />
              </el-col>
            </el-row>
            <el-row :gutter="20">
              <el-col :span="12">
                <el-statistic title="创建日期" :value="underwaterModel.createdDate" />
              </el-col>
              <el-col :span="12">
                <el-statistic title="更新日期" :value="underwaterModel.lastUpdateDate" />
              </el-col>
            </el-row>
          </el-card>
          <el-empty v-else description="加载中..." />
        </div>
      </div>
    </Transition>

    <!-- 底部控制栏 -->
    <div class="babylon-footer">
      <div class="footer-content">
        <span>当前风机: {{ currentWindmillName }}</span>
        <span class="spacer"></span>
        <span v-if="isMeasuring" class="status-active">⚫ 测量模式激活</span>
        <span v-else class="status-normal">查看模式</span>
        <span class="spacer"></span>
        <span>© 2025 Mars3D GIS Platform</span>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, computed, watch, onBeforeUnmount } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import { ElMessage } from 'element-plus'
import {
  ArrowLeft,
  Refresh,
  Tickets,
  Download,
  Close,
  Delete,
  DataAnalysis,
  CircleCloseFilled
} from '@element-plus/icons-vue'
import {
  mockWindFarms,
  convertToTreeData,
  getWindmillById,
  getFarmByWindmillId,
  getSiblingWindmills,
  getUnderwaterModelDetail,
  type Windmill,
  type UnderwaterModelDetail,
  type TreeNode
} from '@/data/windmills'
import { babylonService } from '@/services/babylon/BabylonService'
import { volumeCalculationService, type VolumeResult } from '@/services/babylon/VolumeCalculationService'

const router = useRouter()
const route = useRoute()

// ============== 数据初始化 ==============

const windmillId = ref(route.params.id as string)
const currentWindmillData = ref<Windmill | null>(null)
const underwaterModel = ref<UnderwaterModelDetail | null>(null)

// 从参数加载当前风机数据
const initializeCurrentWindmill = () => {
  console.log('初始化当前风机，windmillId:', windmillId.value)
  const windmill = getWindmillById(windmillId.value)
  if (windmill) {
    console.log('找到风机:', windmill)
    currentWindmillData.value = windmill
    underwaterModel.value = getUnderwaterModelDetail(windmillId.value)
    const farm = getFarmByWindmillId(windmillId.value)
    if (farm) {
      currentFarmId.value = farm.id
      console.log('设置当前风电场:', farm.name)
    }
  } else {
    console.error('风机信息不存在:', windmillId.value)
    ElMessage.error('风机信息不存在')
    router.push('/map')
  }
}

// ============== 树形结构 ==============

const treeData = ref<TreeNode[]>([])
const treeRef = ref()
const currentFarmId = ref('')
const currentWindmillId = computed(() => windmillId.value)

const initializeTreeData = () => {
  treeData.value = convertToTreeData(mockWindFarms)
  console.log('树形数据初始化:', treeData.value)
  // 设置当前风机为高亮
  if (treeRef.value && windmillId.value) {
    setTimeout(() => {
      treeRef.value.setCurrentKey(windmillId.value)
      console.log('设置当前高亮风机:', windmillId.value)
    }, 100)
  }
}

const handleTreeNodeClick = (data: any, node: any) => {
  // Element Plus tree 的 node-click 事件回调：(data, node, component)
  // data 是节点数据，node 是树节点对象
  console.log('树节点点击:', data)
  if (data.type === 'windmill') {
    // 点击风机节点，切换到该风机
    switchWindmill(data.id)
  }
}

const switchWindmill = (newWindmillId: string) => {
  console.log('切换风机:', newWindmillId)
  
  if (newWindmillId === windmillId.value) {
    console.log('同一个风机，不需要切换')
    return // 同一个风机，不需要切换
  }

  const newWindmill = getWindmillById(newWindmillId)
  if (!newWindmill) {
    console.error('无法找到指定风机:', newWindmillId)
    ElMessage.error('无法找到指定风机')
    return
  }

  console.log('开始切换风机:', newWindmill.name)

  // 更新路由参数
  windmillId.value = newWindmillId
  router.replace(`/model/@{newWindmillId}`)

  // 更新风机数据
  currentWindmillData.value = newWindmill
  underwaterModel.value = getUnderwaterModelDetail(newWindmillId)

  // 清空测量数据
  clearMeasurement()
  measurePoints.value = []
  savedResults.value = []

  // 重新加载模型
  loadModelToScene(newWindmill.underwaterModelUrl)
}

// ============== BabylonJS 模型加载 ==============

const isModelLoading = ref(false)

const loadModelToScene = async (modelUrl: string) => {
  if (!modelUrl) {
    ElMessage.error('模型 URL 不存在')
    return
  }

  try {
    isModelLoading.value = true
    
    // 清理旧模型
    babylonService.clearScene()

    // 加载新模型
    const mesh = await babylonService.loadModel(modelUrl, (evt: ProgressEvent) => {
      if (evt.lengthComputable) {
        const percentComplete = (evt.loaded / evt.total) * 100
        console.log(`📦 加载进度: @{percentComplete.toFixed(1)}%`)
      }
    })

    if (mesh) {
      ElMessage.success('模型加载成功')
      console.log('✅ 模型已加载到场景')
    } else {
      ElMessage.error('模型加载失败')
    }
  } catch (error) {
    console.error('❌ 加载模型失败:', error)
    ElMessage.error('模型加载失败，请检查模型文件')
  } finally {
    isModelLoading.value = false
  }
}

// ============== UI 状态 ==============

const leftPanelOpen = ref(true)
const infoPanelOpen = ref(true)
const isMeasuring = ref(false)
const measureMode = ref('distance')

// ============== 测量工具 ==============

const measurePoints = ref([])
const measureResult = ref<VolumeResult | null>(null)
const savedResults = ref<VolumeResult[]>([])
const targetHeight = ref(0) // 基准高度（单位：米）
const sampleResolution = ref(0.5) // 采样分辨率（单位：米）

const toggleMeasurement = () => {
  isMeasuring.value = !isMeasuring.value
  if (isMeasuring.value) {
    ElMessage.info('测量模式已激活，输入基准高度后点击"计算方量"')
  } else {
    ElMessage.info('测量模式已关闭')
  }
}

const calculateCutFill = async () => {
  const scene = babylonService.getScene()
  const model = babylonService.getCurrentModel()

  if (!scene || !model) {
    ElMessage.error('场景或模型未加载')
    return
  }

  try {
    isModelLoading.value = true

    // 验证基准高度
    if (!volumeCalculationService.validateTargetHeight(model, targetHeight.value)) {
      ElMessage.warning('基准高度可能不合理，但仍继续计算')
    }

    // 执行方量计算
    measureResult.value = volumeCalculationService.calculateVolume(
      scene,
      model,
      targetHeight.value,
      sampleResolution.value
    )

    ElMessage.success('方量计算完成')
  } catch (error) {
    console.error('❌ 方量计算失败:', error)
    ElMessage.error('方量计算失败')
  } finally {
    isModelLoading.value = false
  }
}

const handleMeasureMode = (mode: string) => {
  measurePoints.value = []
  measureResult.value = null
  ElMessage.info(`切换到@{getModeLabel(mode)}模式`)
}

const getModeLabel = (mode: string): string => {
  const modeMap: Record<string, string> = { distance: '距离', area: '面积', volume: '体积' }
  return modeMap[mode] || '未知'
}

const deletePoint = (index: number) => {
  measurePoints.value.splice(index, 1)
  measureResult.value = null
}

const clearMeasurement = () => {
  measurePoints.value = []
  measureResult.value = null
}

const saveMeasurement = () => {
  if (measureResult.value) {
    savedResults.value.push({
      ...measureResult.value,
      cutVolume: measureResult.value.cutVolume,
      fillVolume: measureResult.value.fillVolume,
      horizontalArea: measureResult.value.horizontalArea
    })
    ElMessage.success('测量结果已保存')
    measureResult.value = null
  }
}

const deleteSavedResult = (index: number) => {
  savedResults.value.splice(index, 1)
}

// ============== 其他方法 ==============

const resetCamera = () => {
  ElMessage.info('相机已重置')
}

const getStatusLabel = (status: string): string => {
  const statusMap: Record<string, string> = {
    running: '运行中',
    maintenance: '维护中',
    offline: '离线',
    fault: '故障'
  }
  return statusMap[status] || '未知'
}

const getStatusTagType = (status: string): string => {
  const typeMap: Record<string, string> = {
    running: 'success',
    maintenance: 'warning',
    offline: 'info',
    fault: 'danger'
  }
  return typeMap[status] || 'info'
}

const getStatusIconClass = (status?: string): string => {
  if (!status) return ''
  const classMap: Record<string, string> = {
    running: 'status-running',
    maintenance: 'status-maintenance',
    offline: 'status-offline',
    fault: 'status-fault'
  }
  return classMap[status] || ''
}

// ============== 计算属性 ==============

const currentWindmillName = computed(() => currentWindmillData.value?.name || '加载中...')

// ============== 生命周期 ==============

import { onMounted } from 'vue'

onMounted(() => {
  console.log('🎬 ModelDetailContainer 已挂载')
  console.log('📍 当前路由参数:', route.params.id)
  
  // 初始化数据
  initializeCurrentWindmill()
  initializeTreeData()

  // 初始化 BabylonJS 场景
  const canvas = document.getElementById('renderCanvas') as HTMLCanvasElement
  if (canvas) {
    const success = babylonService.initScene(canvas)
    if (success && currentWindmillData.value) {
      // 加载当前风机的模型
      setTimeout(() => {
        loadModelToScene(currentWindmillData.value!.underwaterModelUrl)
      }, 100)
    }
  } else {
    console.error('❌ 未找到 canvas 元素')
  }
})

// 组件卸载前清理资源
onBeforeUnmount(() => {
  console.log('🔌 ModelDetailContainer 卸载中')
  babylonService.dispose()
})
</script>

<style scoped lang="less">
// 色彩系统 - 科技大屏风格
@primary-blue: #00d4ff;
@secondary-blue: #0099ff;
@success-green: #00ff88;
@warning-orange: #ffaa00;
@danger-red: #ff4444;
@dark-bg: rgba(10, 25, 47, 0.85);
@panel-bg: rgba(15, 35, 65, 0.9);
@border-color: rgba(0, 212, 255, 0.2);
@text-primary: #e0e6ed;
@text-secondary: #a0aec0;
@text-light: #64748b;
@accent-glow: 0 0 20px rgba(0, 212, 255, 0.3);

.model-detail-container {
  width: 100%;
  height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #0a1e3a 0%, #1a0e2e 100%);
  overflow: hidden;

  .babylon-canvas {
    flex: 1;
    width: 100%;
    height: 100%;
  }

  // ========== 顶部工具栏 ==========
  .babylon-toolbar {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    height: 56px;
    background: @panel-bg;
    border: 1px solid @border-color;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), @accent-glow;
    z-index: 100;
    padding: 0 20px;
    backdrop-filter: blur(10px);

    .toolbar-content {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;

      .back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: @primary-blue;
        text-decoration: none;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 6px 12px;
        border-radius: 6px;
        border: 1px solid transparent;

        &:hover {
          color: lighten(@primary-blue, 10%);
          border-color: @primary-blue;
          box-shadow: 0 0 12px rgba(0, 212, 255, 0.3);
        }

        .el-icon {
          font-size: 16px;
        }
      }

      .title {
        flex: 1;
        font-weight: 600;
        font-size: 18px;
        color: @text-primary;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
      }

      .toolbar-actions {
        display: flex;
        gap: 12px;

        :deep(.el-button) {
          background: rgba(0, 153, 255, 0.15) !important;
          border: 1px solid @primary-blue !important;
          color: @primary-blue !important;
          border-radius: 6px;
          transition: all 0.3s ease;

          &:hover {
            background: rgba(0, 153, 255, 0.3) !important;
            box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
          }
        }
      }
    }
  }

  // ========== 左侧测量面板 ==========
  .left-panel {
    position: absolute;
    top: 75px;
    left: 12px;
    width: 340px;
    max-height: calc(100vh - 140px);
    background: @panel-bg;
    border: 1px solid @border-color;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), @accent-glow;
    z-index: 50;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    backdrop-filter: blur(10px);

    :deep(.el-tabs) {
      display: flex;
      flex-direction: column;
      height: 100%;
      background: transparent;

      .el-tabs__header {
        margin: 0;
        border-bottom: 1px solid @border-color;
        background: rgba(0, 0, 0, 0.2);
      }

      .el-tabs__nav-wrap::after {
        background: none;
      }

      .el-tabs__item {
        color: @text-secondary !important;
        transition: all 0.3s ease;

        &.is-active {
          color: @primary-blue !important;
          border-bottom-color: @primary-blue !important;
          box-shadow: inset 0 -2px 0 @primary-blue;
        }

        &:hover {
          color: @primary-blue !important;
        }
      }

      .el-tabs__content {
        flex: 1;
        overflow-y: auto;
        background: transparent;
      }
    }

    .panel-content {
      padding: 18px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 16px;

      &::-webkit-scrollbar {
        width: 6px;
      }

      &::-webkit-scrollbar-track {
        background: rgba(0, 212, 255, 0.1);
        border-radius: 3px;
      }

      &::-webkit-scrollbar-thumb {
        background: rgba(0, 212, 255, 0.3);
        border-radius: 3px;

        &:hover {
          background: rgba(0, 212, 255, 0.5);
        }
      }

      label {
        font-weight: 600;
        font-size: 12px;
        color: @text-primary;
        display: block;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
      }

      // 方量计算部分
      .cut-fill-section {
        padding: 14px;
        background: rgba(0, 153, 255, 0.08);
        border: 1px solid @border-color;
        border-radius: 6px;

        .input-group {
          margin-bottom: 14px;

          label {
            margin-bottom: 8px;
          }

          :deep(.el-input-number) {
            width: 100% !important;

            .el-input__wrapper {
              background: rgba(0, 0, 0, 0.3) !important;
              border: 1px solid @border-color !important;
              color: @text-primary !important;
            }

            input {
              color: @text-primary !important;
              background: transparent !important;
            }
          }
        }

        :deep(.el-divider) {
          margin: 16px 0 12px 0;
          border-color: @border-color;
        }

        :deep(.el-button) {
          width: 100%;
          background: linear-gradient(135deg, @secondary-blue 0%, @primary-blue 100%) !important;
          border: none !important;
          color: white !important;
          border-radius: 6px;
          font-weight: 600;
          transition: all 0.3s ease;
          margin-bottom: 12px;

          &:hover {
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
            transform: translateY(-2px);
          }
        }

        .result-display {
          margin-top: 12px;

          :deep(.el-card) {
            border: 1px solid @border-color !important;
            background: rgba(0, 153, 255, 0.1) !important;
            box-shadow: inset 0 0 20px rgba(0, 212, 255, 0.1);

            .el-card__header {
              border-bottom: 1px solid @border-color;
              background: rgba(0, 0, 0, 0.2);
            }
          }

          :deep(.el-statistic__title) {
            color: @text-secondary !important;
            font-size: 12px;
          }

          :deep(.el-statistic__content) {
            font-size: 20px;
            font-weight: 700;
            color: @primary-blue;
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
          }
        }
      }

      // 树形结构
      :deep(.el-tree) {
        background: transparent;

        .el-tree-node__content {
          height: 36px;
          border-radius: 4px;
          transition: all 0.3s ease;

          &:hover {
            background: rgba(0, 212, 255, 0.1);
          }
        }

        .tree-node {
          display: flex;
          align-items: center;
          gap: 8px;
          font-size: 13px;
          cursor: pointer;
          padding: 0 8px;
          color: @text-secondary;
          transition: all 0.3s ease;

          &.active {
            background: rgba(0, 212, 255, 0.15);
            color: @primary-blue;
            border-radius: 4px;
            box-shadow: inset 0 0 12px rgba(0, 212, 255, 0.1);
          }

          .farm-node {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 600;
            color: @primary-blue;

            .el-icon {
              color: @primary-blue;
            }
          }

          .windmill-node {
            display: flex;
            align-items: center;
            gap: 6px;
            color: @text-secondary;

            .el-icon {
              width: 12px;
              height: 12px;
              font-size: 12px;
              border-radius: 50%;

              &.status-running {
                color: @success-green;
                box-shadow: 0 0 8px @success-green;
              }

              &.status-maintenance {
                color: @warning-orange;
                box-shadow: 0 0 8px @warning-orange;
              }

              &.status-offline {
                color: @text-light;
              }

              &.status-fault {
                color: @danger-red;
                box-shadow: 0 0 8px @danger-red;
              }
            }
          }
        }
      }

      // 测量模式
      .measure-mode {
        :deep(.el-radio-group) {
          display: flex;
          flex-direction: column;
          gap: 8px;
        }

        :deep(.el-radio) {
          color: @text-secondary;

          .el-radio__label {
            color: @text-secondary;
          }

          input[type='radio']:checked + .el-radio__label {
            color: @primary-blue;
          }
        }
      }

      // 测量点列表
      .measure-points,
      .saved-results {
        .points-list,
        .results-list {
          max-height: 120px;
          overflow-y: auto;
          display: flex;
          flex-direction: column;
          gap: 8px;
          margin-top: 8px;

          .point-item,
          .result-item {
            padding: 10px;
            background: rgba(0, 153, 255, 0.08);
            border: 1px solid @border-color;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            transition: all 0.3s ease;

            &:hover {
              border-color: @primary-blue;
              background: rgba(0, 153, 255, 0.12);
            }

            .point-num,
            .result-type {
              min-width: 30px;
              font-weight: 600;
              color: @primary-blue;
            }

            .point-coords,
            .result-value {
              flex: 1;
              overflow: hidden;
              text-overflow: ellipsis;
              white-space: nowrap;
              color: @text-secondary;
            }

            .delete-btn {
              cursor: pointer;
              color: @text-light;
              transition: all 0.3s ease;

              &:hover {
                color: @danger-red;
                transform: scale(1.2);
              }
            }
          }
        }
      }
    }
  }

  // ========== 右侧信息面板 ==========
  .info-panel {
    position: absolute;
    top: 75px;
    right: 12px;
    width: 340px;
    max-height: calc(100vh - 140px);
    background: @panel-bg;
    border: 1px solid @border-color;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), @accent-glow;
    z-index: 50;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    backdrop-filter: blur(10px);

    .panel-content {
      flex: 1;
      padding: 18px;
      overflow-y: auto;
      color: @text-secondary;

      &::-webkit-scrollbar {
        width: 6px;
      }

      &::-webkit-scrollbar-track {
        background: rgba(0, 212, 255, 0.1);
        border-radius: 3px;
      }

      &::-webkit-scrollbar-thumb {
        background: rgba(0, 212, 255, 0.3);
        border-radius: 3px;

        &:hover {
          background: rgba(0, 212, 255, 0.5);
        }
      }

      :deep(.el-card) {
        background: rgba(0, 153, 255, 0.08) !important;
        border: 1px solid @border-color !important;
        margin-bottom: 14px;

        .el-card__header {
          border-bottom: 1px solid @border-color;
          background: rgba(0, 0, 0, 0.2);
          padding: 12px 16px;
        }

        .el-card__body {
          padding: 14px 16px;
        }
      }

      :deep(.el-statistic__title) {
        color: @text-secondary !important;
        font-size: 12px;
      }

      :deep(.el-statistic__content) {
        color: @primary-blue;
        font-weight: 600;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
      }

      :deep(.el-tag) {
        background: rgba(0, 153, 255, 0.2) !important;
        border-color: @primary-blue !important;
        color: @primary-blue !important;

        &.el-tag--success {
          background: rgba(0, 255, 136, 0.2) !important;
          border-color: @success-green !important;
          color: @success-green !important;
        }

        &.el-tag--warning {
          background: rgba(255, 170, 0, 0.2) !important;
          border-color: @warning-orange !important;
          color: @warning-orange !important;
        }

        &.el-tag--danger {
          background: rgba(255, 68, 68, 0.2) !important;
          border-color: @danger-red !important;
          color: @danger-red !important;
        }
      }
    }
  }

  // ========== 底部控制栏 ==========
  .babylon-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 48px;
    background: linear-gradient(180deg, transparent 0%, @dark-bg 100%);
    border-top: 1px solid @border-color;
    color: @text-secondary;
    z-index: 40;

    .footer-content {
      height: 100%;
      display: flex;
      align-items: center;
      padding: 0 20px;
      font-size: 12px;
      gap: 20px;
      letter-spacing: 0.5px;

      .spacer {
        flex: 1;
      }

      .status-active {
        color: @success-green;
        font-weight: 600;
        text-shadow: 0 0 10px rgba(0, 255, 136, 0.3);
      }

      .status-normal {
        color: @text-light;
      }
    }
  }
}

// ========== 全局滚动条样式 ==========
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: rgba(0, 212, 255, 0.08);
}

::-webkit-scrollbar-thumb {
  background: rgba(0, 212, 255, 0.3);
  border-radius: 3px;

  &:hover {
    background: rgba(0, 212, 255, 0.5);
  }
}

// ========== 动画 ==========
:deep(.slide-fade-enter-active),
:deep(.slide-fade-leave-active) {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

:deep(.slide-fade-enter-from) {
  transform: translateX(-30px);
  opacity: 0;
}

:deep(.slide-fade-leave-to) {
  transform: translateX(-30px);
  opacity: 0;
}

:deep(.slide-fade-right-enter-active),
:deep(.slide-fade-right-leave-active) {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

:deep(.slide-fade-right-enter-from) {
  transform: translateX(30px);
  opacity: 0;
}

:deep(.slide-fade-right-leave-to) {
  transform: translateX(30px);
  opacity: 0;
}
</style>

